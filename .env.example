# Copy this file to .env and fill in real values. .env is gitignored.

# --- Container provisioning (read by docker-compose) ---
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=change-me
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-too

# --- App: MongoDB client ---
# URI must match the container credentials above.
MONGO_URI=mongodb://admin:change-me@localhost:27017
MONGO_DATABASE=legal_scraper
MONGO_LANDING_COLLECTION=landing_metadata
MONGO_CLEAN_COLLECTION=clean_metadata

# --- App: MinIO / S3 client ---
# Access/secret keys must match the MinIO root user/password above.
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-too
MINIO_REGION=us-east-1
MINIO_LANDING_BUCKET=landing-zone
MINIO_CLEAN_BUCKET=clean-zone

# --- App: scraping behaviour ---
PARTITION_MONTHS=1
CONCURRENT_REQUESTS=16
DOWNLOAD_DELAY=0.5
AUTOTHROTTLE_ENABLED=true
RETRY_TIMES=3
USER_AGENT=legal-scraper/0.1 (+https://example.com)
